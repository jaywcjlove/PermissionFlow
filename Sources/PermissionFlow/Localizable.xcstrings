    "Drag **%@** to the list above to allow **%@**" : {
      "comment" : "PermissionFlow helper panel instruction. First placeholder is app name, second is permission title. Keep markdown ** ** around placeholders to make them bold.",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اسحب **%1$@** إلى القائمة أعلاه للسماح بـ **%2$@**"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Přetažením aplikace **%1$@** do výše uvedeného seznamu povolíte **%2$@**"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Træk **%1$@** til listen ovenfor for at tillade **%2$@**"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ziehe **%1$@** in die obige Liste, um **%2$@** zu erlauben"
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Σύρετε το **%1$@** στη λίστα παραπάνω για να επιτρέψετε το **%2$@**"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Drag **%1$@** to the list above to allow **%2$@**"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arrastra **%1$@** a la lista de arriba para permitir **%2$@**"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Faites glisser **%1$@** vers la liste ci-dessus pour autoriser **%2$@**"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seret **%1$@** ke daftar di atas untuk mengizinkan **%2$@**"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trascina **%1$@** nell'elenco in alto per consentire **%2$@**"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**%1$@** を上のリストにドラッグして、**%2$@** を許可してください"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**%1$@**을(를) 위 목록으로 드래그하여 **%2$@**을(를) 허용하세요"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przeciągnij **%1$@** na listę powyżej, aby zezwolić na **%2$@**"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arraste **%1$@** para a lista acima para permitir **%2$@**"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trageți **%1$@** în lista de mai sus pentru a permite **%2$@**"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Перетащите **%1$@** в список выше, чтобы разрешить **%2$@**"
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ลาก **%1$@** ไปยังรายการด้านบนเพื่ออนุญาต **%2$@**"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**%1$@** öğesini **%2$@** izni vermek için yukarıdaki listeye sürükleyin"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Перетягніть **%1$@** до списку вище, щоб дозволити **%2$@**"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kéo **%1$@** vào danh sách phía trên để cho phép **%2$@**"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将 **%1$@** 拖到上方列表中以允许 **%2$@**"
